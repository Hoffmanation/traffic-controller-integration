{
    "openapi": "3.1.0",
    "info": {
        "title": "OpenAPI definition",
        "version": "v0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Generated server url"
        }
    ],
    "tags": [
        {
            "name": "Detector Readings",
            "description": "Endpoints for retrieving real-time and historical sensor data"
        },
        {
            "name": "Controller Commands",
            "description": "Endpoints for sending remote commands to traffic devices"
        },
        {
            "name": "Controller Status",
            "description": "Endpoints for monitoring real-time and historical controller states"
        }
    ],
    "paths": {
        "/api/v1/controllers/{controllerId}/commands": {
            "get": {
                "tags": [
                    "Controller Commands"
                ],
                "summary": "Get command history",
                "description": "Returns a full historical list of all commands sent to this controller, sorted by newest first, with pagination",
                "operationId": "getCommandHistory",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Historical audit log retrieved",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CommandResult"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Controller Commands"
                ],
                "summary": "Send command to device",
                "description": "Sends a specific command to the remote controller and logs the audit trail",
                "operationId": "sendCommand",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SendCommandRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Command successfully dispatched and result recorded",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/CommandResult"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Controller not found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/CommandResult"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/controllers/{controllerId}/status": {
            "get": {
                "tags": [
                    "Controller Status"
                ],
                "summary": "Get current status",
                "description": "Fetches the latest state from Redis or directly from the DB",
                "operationId": "getCurrentStatus",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "description": "ID of the controller",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fd35.z1.suburb12.loc"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved current status",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ControllerStatus"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Controller not found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ControllerStatus"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/controllers/{controllerId}/status/history": {
            "get": {
                "tags": [
                    "Controller Status"
                ],
                "summary": "Get status history",
                "description": "Returns a historical controller status, newest first with pagination",
                "operationId": "getStatusHistory",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "description": "ID of the controller",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fd35.z1.suburb12.loc"
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Historical status log retrieved",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/ControllerStatus"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/controllers/{controllerId}/detectors": {
            "get": {
                "tags": [
                    "Detector Readings"
                ],
                "summary": "Get latest readings",
                "description": "Retrieves the latest detector readings for a specific controller from Redis or directly from the DB",
                "operationId": "getLatestReadings",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "description": "ID of the controller",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fd35.z1.suburb12.loc"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved readings",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DetectorReading"
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Controller not found",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DetectorReading"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/controllers/{controllerId}/detectors/{detectorName}": {
            "get": {
                "tags": [
                    "Detector Readings"
                ],
                "summary": "Get latest readings for specific detector",
                "description": "Retrieves the latest data for a specific detector with pagination",
                "operationId": "getDetectorReadingsByPagination",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "description": "ID of the controller",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fd35.z1.suburb12.loc"
                    },
                    {
                        "name": "detectorName",
                        "in": "path",
                        "description": "The name of the detector",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "D1"
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved history",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DetectorReading"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/controllers/{controllerId}/detectors/{detectorName}/history": {
            "get": {
                "tags": [
                    "Detector Readings"
                ],
                "summary": "Get detector history",
                "description": "Retrieves historical data for a specific detector filtered by time range",
                "operationId": "getDetectorHistoryByTimeRange",
                "parameters": [
                    {
                        "name": "controllerId",
                        "in": "path",
                        "description": "ID of the controller",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "fd35.z1.suburb12.loc"
                    },
                    {
                        "name": "detectorName",
                        "in": "path",
                        "description": "The name of the detector",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "D1"
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "description": "Start timestamp (ISO-8601)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "example": "2026-03-08T10:00:00Z"
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "description": "End timestamp (ISO-8601)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "example": "2026-03-08T11:00:00Z"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved history",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DetectorReading"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "SendCommandRequest": {
                "type": "object",
                "description": "Payload for dispatching a new command to a traffic controller",
                "properties": {
                    "command": {
                        "type": "string",
                        "description": "The command string to be sent to the device"
                    }
                },
                "required": [
                    "command"
                ]
            },
            "CommandResult": {
                "type": "object",
                "description": "Response object representing a recorded command audit trail",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Primary Key of the command",
                        "example": 1234,
                        "readOnly": true
                    },
                    "controllerId": {
                        "type": "string",
                        "description": "Primary Key of the traffic controller",
                        "example": "fd11.z1.downtown.loc",
                        "readOnly": true
                    },
                    "success": {
                        "type": "boolean",
                        "description": "if command wad success or not",
                        "example": "SUCCESS",
                        "readOnly": true
                    },
                    "resultValue": {
                        "type": "string",
                        "description": "The raw return value or acknowledgment from the hardware",
                        "readOnly": true
                    },
                    "deviceTimestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp when the command was processed by the device",
                        "example": "2026-03-07T14:00:00Z",
                        "readOnly": true
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp when this record created in the DB",
                        "example": "2026-03-07T13:59:58Z",
                        "readOnly": true
                    },
                    "command": {
                        "type": "string",
                        "description": "The specific command instruction dispatched",
                        "enum": [
                            "CHANGE_PROGRAM",
                            "RESET_PROGRAM",
                            "PAUSE_PROGRAM"
                        ],
                        "example": "CHANGE_PROGRAM",
                        "readOnly": true
                    }
                }
            },
            "ControllerError": {
                "type": "object",
                "description": "Error detail from the traffic controller",
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "error code",
                        "example": "E101"
                    },
                    "message": {
                        "type": "string",
                        "description": "Detailed description of the error",
                        "example": "Detector D3 malfunction"
                    }
                }
            },
            "ControllerStatus": {
                "type": "object",
                "description": "Current status of the traffic controller",
                "properties": {
                    "controllerId": {
                        "type": "string",
                        "description": "Primary Key of the traffic controller",
                        "example": "fd132.z1.highway.a21.loc"
                    },
                    "state": {
                        "type": "string",
                        "description": "operational state state of the contorller",
                        "enum": [
                            "OPERATIONAL",
                            "DETECTOR_FAILURE",
                            "SIGNAL_FAILURE",
                            "COMMUNICATION_LOST",
                            "MAINTENANCE",
                            "UNKNOWN"
                        ],
                        "example": "OPERATIONAL"
                    },
                    "program": {
                        "type": "string",
                        "description": "the program on the traffic controller",
                        "example": "SP1"
                    },
                    "errors": {
                        "type": "array",
                        "description": "Collection of protocol errors",
                        "items": {
                            "$ref": "#/components/schemas/ControllerError"
                        }
                    },
                    "deviceTimestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp reported by the controller",
                        "example": "2026-03-07T18:40:00Z"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp when this record created in the DB",
                        "example": "2026-03-07T18:40:02Z",
                        "readOnly": true
                    }
                },
                "required": [
                    "controllerId"
                ]
            },
            "DetectorReading": {
                "type": "object",
                "description": "Data from a specific Detector",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Primary Key of the detector reading data table",
                        "example": 1001,
                        "readOnly": true
                    },
                    "controllerId": {
                        "type": "string",
                        "description": "Primary Key of the traffic controller",
                        "example": "fd132.z1.highway.a21.loc"
                    },
                    "detectorNumber": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Detector number",
                        "example": 1
                    },
                    "detectorName": {
                        "type": "string",
                        "description": "Detector name",
                        "example": "D1 - Northbound"
                    },
                    "vehicleCount": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Number of vehicles detected",
                        "example": 12
                    },
                    "occupancy": {
                        "type": "number",
                        "format": "double",
                        "description": "Percentage of road occupancy",
                        "example": 0.23
                    },
                    "deviceTimestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp reported by the controller",
                        "example": "2026-03-07T21:00:00Z"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp when this record created in the DB",
                        "example": "2026-03-07T21:00:05Z",
                        "readOnly": true
                    }
                },
                "required": [
                    "controllerId",
                    "detectorNumber"
                ]
            }
        }
    }
}